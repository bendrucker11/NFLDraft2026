# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: ISO-8601 timestamp — block new submissions at or after this instant
# SUBMISSIONS_LOCK_AT=2026-04-24T23:59:59Z

# Optional: shared secret for /admin (plain string; pick something long and random)
# ADMIN_SECRET=replace-with-a-long-random-string
