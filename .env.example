# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: ISO-8601 timestamp — block new submissions at or after this instant
# Defaults to 2026-04-23T19:30:00-04:00 if not set
# SUBMISSIONS_LOCK_AT=2026-04-23T19:30:00-04:00

# Optional: reveal leaderboard to non-admins at/after this instant
# Defaults to 2026-04-23T20:00:00-04:00 if not set
# LEADERBOARD_REVEAL_AT=2026-04-23T20:00:00-04:00

# Required for admin login at /admin (plain string; pick something long and random)
ADMIN_SECRET=replace-with-a-long-random-string
